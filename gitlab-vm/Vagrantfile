# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Используем актуальный образ Ubuntu 22.04 (Jammy)
  config.vm.box = "ubuntu/jammy64"
  
  # Настраиваем сеть: пробрасываем порты GitLab (HTTP, SSH) на хост
  config.vm.network "forwarded_port", guest: 80, host: 8080     # GitLab Web UI
  config.vm.network "forwarded_port", guest: 22, host: 2222     # SSH для Git
  config.vm.network "forwarded_port", guest: 443, host: 8443    # GitLab HTTPS (опционально)

  # Выделяем ресурсы для виртуальной машины
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "4096"  # 4GB RAM (рекомендуемый минимум для GitLab)
    vb.cpus = 2          # 2 CPU ядра
    vb.name = "gitlab-server"
  end

  # Shell-скрипт для установки и настройки GitLab
  config.vm.provision "shell", inline: <<-SHELL
    # Обновляем пакеты
    apt-get update
    apt-get install -y curl openssh-server ca-certificates tzdata perl

    # Устанавливаем GitLab CE (Community Edition) по официальной инструкции
    curl -sS https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.deb.sh | bash
    EXTERNAL_URL="http://192.168.100.10" apt-get install -y gitlab-ce
  SHELL
end
